# 从 Google Cloud Console 获取 YouTube Data API v3 Key
YOUTUBE_API_KEY=your_api_key_here

# 快照去重粒度：hour（默认，同一视频同一小时只写一条）或 minute
DEDUP_GRANULARITY=hour

# MySQL 连接（可用 docker compose up -d 启动本地库）
# Local dev: use 127.0.0.1; Docker Compose overrides this to mysql container automatically
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/kol_youtube?charset=utf8mb4

# MySQL root password (used by docker-compose.yml)
MYSQL_ROOT_PASSWORD=password

# CORS allowed origins (comma-separated, include your production domain)
# e.g. CORS_ORIGINS=https://monitor.yourdomain.com,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
