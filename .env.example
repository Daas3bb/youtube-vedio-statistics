# 从 Google Cloud Console 获取 YouTube Data API v3 Key
YOUTUBE_API_KEY=your_api_key_here

# 快照去重粒度：hour（默认，同一视频同一小时只写一条）或 minute
DEDUP_GRANULARITY=hour

# ── 本地开发代理（国内访问 Google API 必填，GitHub Actions 不需要）──
# Clash / VPN 的 HTTP 代理端口（常见 7890、7897）
PROXY_PORT=7897
# 或直接写完整代理地址（若设置则优先于 PROXY_PORT）
# HTTPS_PROXY=http://127.0.0.1:7897
